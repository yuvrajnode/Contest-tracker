# PostgreSQL connection string (required for full functionality)
# Without this, the app runs on mock data automatically
DATABASE_URL="postgresql://user:password@host:5432/contest_tracker"

# YouTube Data API v3 key (optional - needed for auto-fetch solution links)
YOUTUBE_API_KEY=""

# YouTube channel IDs for auto-fetching editorial links (optional)
CODEFORCES_CHANNEL_ID=""
CODECHEF_CHANNEL_ID=""
LEETCODE_CHANNEL_ID=""
